# ─── Environment Variables ───
# Copy this file to .env and fill in the values

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/stock_portfolio?schema=public"

# LLM API key (Gemini or OpenAI — used in Phase 2)
LLM_API_KEY="your-api-key-here"

# FastAPI service URL (used by Next.js to proxy requests)
MARKET_DATA_API_URL="http://localhost:8000"

# ─── Auth ───
JWT_SECRET="change-this-to-a-random-64-char-secret-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# ─── Storage (local | s3) ───
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./uploads"
# S3_BUCKET=""
# AWS_REGION=""

# ─── Mailer (console | smtp) ───
MAILER_PROVIDER="console"
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM=""

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"
